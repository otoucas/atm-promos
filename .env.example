# Copy this file to .env and fill in your own values before running.

# Mot de passe pour la section admin (validation des promotions, config).
ADMIN_PASSWORD=changeme

# Clé utilisée pour signer les cookies de session — mettre une chaîne aléatoire longue.
SECRET_KEY=change-this-to-a-long-random-string

# --- Boîte Gmail utilisée pour recevoir les promotions HighCo ---
# 1. Activer la validation en 2 étapes sur le compte Google.
# 2. Créer un "mot de passe d'application" : https://myaccount.google.com/apppasswords
# 3. Renseigner l'adresse et ce mot de passe ci-dessous (pas le mot de passe normal du compte).
GMAIL_ADDRESS=votre-boite@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_MAILBOX=INBOX
# Filtre optionnel pour ne lire que les mails d'un expéditeur/domaine précis (ex: highco.com)
GMAIL_SENDER_FILTER=

# Fréquence de vérification des nouveaux mails (minutes)
POLL_INTERVAL_MINUTES=15
# Fréquence de vérification des promotions expirées à archiver (minutes)
ARCHIVE_CHECK_INTERVAL_MINUTES=60

# Mettre à 1 pour désactiver complètement le relevé Gmail automatique (saisie manuelle uniquement)
DISABLE_GMAIL_POLLER=0

# --- Exposition réseau ---
# Par défaut, le conteneur écoute sur toutes les interfaces (0.0.0.0), adapté
# si l'hôte lui-même n'est déjà accessible que depuis le réseau local du
# comptoir. Si l'hôte a une IP publique (serveur distant, VPS...), restreindre
# BIND_ADDRESS à une adresse privée uniquement joignable via VPN (ex: l'IP
# Tailscale de la machine) pour éviter d'exposer la génération de codes sur
# Internet.
BIND_ADDRESS=0.0.0.0
HOST_PORT=8000
